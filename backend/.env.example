# Copia este archivo como `.env` (queda gitignored) y ajustá los valores.
# Defaults seguros para desarrollo local.

# ---------- Database ----------
# Dev local — SQLite (default, sin instalar nada extra):
DATABASE_URL=sqlite+aiosqlite:///./kabbalah.db
# Dev con Postgres (vía `docker compose up -d postgres` desde la raíz):
#   DATABASE_URL=postgresql+asyncpg://kabbalah:kabbalah_dev@localhost:5432/kabbalah

# ---------- CORS ----------
# Lista separada por coma de orígenes permitidos por el navegador.
# En prod usar el dominio real, NUNCA "*".
CORS_ORIGINS=http://localhost:5173

# ---------- JWT (lo usa issue #7) ----------
# Generá un secret real con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440

# ---------- LLM (lo usa issue #9) ----------
# Valores: stub | claude | gemini
LLM_PROVIDER=stub
LLM_API_KEY=

# ---------- Google OAuth (lo usa issue #24) ----------
# Si los dos primeros quedan vacíos, el botón "Continuar con Google" del
# LoginModal aparece deshabilitado y el resto del flujo de login con
# email/password sigue funcionando normal. Guía paso a paso para obtener
# estos valores: ver README.md → "Configurar Google OAuth (10 min)".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
FRONTEND_URL=http://localhost:5173
