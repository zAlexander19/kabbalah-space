# Copia este archivo como `.env` (queda gitignored) y ajustá los valores.
# Defaults seguros para desarrollo local.

# ---------- Database ----------
# Dev local con SQLite (default). Para Postgres (issue #5):
#   DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/kabbalah
DATABASE_URL=sqlite+aiosqlite:///./kabbalah.db

# ---------- CORS ----------
# Lista separada por coma de orígenes permitidos por el navegador.
# En prod usar el dominio real, NUNCA "*".
CORS_ORIGINS=http://localhost:5173

# ---------- JWT (lo usa issue #7) ----------
# Generá un secret real con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440

# ---------- LLM (lo usa issue #9) ----------
# Valores: stub | claude | gemini
LLM_PROVIDER=stub
LLM_API_KEY=
