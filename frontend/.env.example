# Copiá este archivo como `.env` (gitignored) o seteá la variable en tu host.
#
# URL base del backend para el build de producción, SIN slash final.
# Ejemplo prod:  VITE_API_BASE=https://api.tudominio.com
# En desarrollo podés dejarlo vacío: cae automáticamente a http://127.0.0.1:8000
VITE_API_BASE=
